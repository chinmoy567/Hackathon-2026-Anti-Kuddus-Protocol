PORT=5000
NODE_ENV=development

# Single Atlas cluster, three logical databases (Identity / Anonymous / Domain)
# separated by dbName per Mongoose connection — see src/config/db.js and
# .claude/issues/ISSUES.md Issue 1.
MONGO_BASE_URI=
MONGO_DB_IDENTITY=antikuddus_identity
MONGO_DB_ANONYMOUS=antikuddus_anonymous
MONGO_DB_DOMAIN=antikuddus_domain

JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
REFRESH_TOKEN_EXPIRES_IN=7d

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

CORS_ORIGIN=http://localhost:5173

LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000
TOKEN_ISSUANCE_RATE_LIMIT_MAX=5
TOKEN_ISSUANCE_RATE_LIMIT_WINDOW_MS=600000

# Mission 3 — Syllabus Negotiator. AI Gateway is the only module that reads these keys
# (System Architecture.md Decision D4) — never expose them client-side.
# Chat completions run on Groq (free tier, OpenAI-compatible API, no billing required —
# see .claude/issues/ISSUES.md for the provider-switch rationale from OpenAI/Gemini).
GORQ_API_KEY=
GORQ_CHAT_MODEL=llama-3.3-70b-versatile
# llama-3.3 doesn't support json_schema structured outputs (confirmed) — gpt-oss-120b does.
# Used only by studyPlan.service.js's structured-output chain.
GORQ_STRUCTURED_OUTPUT_MODEL=openai/gpt-oss-120b
SYLLABUS_RATE_LIMIT_MAX=10
SYLLABUS_RATE_LIMIT_WINDOW_MS=600000

# Mission 3 Task 2 — Retrieval & Embedding Service. Embeddings run on Cohere (free tier, no
# billing required — Groq has no embeddings endpoint, see .claude/issues/ISSUES.md). Pinecone
# index must be created manually beforehand: dimension 1024 (matching embed-english-v3.0),
# metric cosine.
COHERE_API_KEY=
COHERE_EMBEDDING_MODEL=embed-english-v3.0
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
# Recalibrated for Cohere (was 0.75 under OpenAI) — real curriculum matches score ~0.67-0.71,
# non-examinable items ~0.43-0.50 against the live seeded index.
CURRICULUM_SIMILARITY_THRESHOLD=0.6

# Mission 3 Task 3 — Smart Study Plan Generator. Tunable weighting constants, not magic
# numbers buried in code.
STUDY_PLAN_DEFAULT_HOURS_PER_DAY=2
STUDY_PLAN_WEAK_SUBJECT_MULTIPLIER=1.5
STUDY_PLAN_EXAM_FREQUENCY_NUDGE_MULTIPLIER=1.15
STUDY_PLAN_MIN_BLOCK_MINUTES=10
